<workflowGraph name="">
  <param name="parentDataDir"/>
  <param name="coreProteome"/>
  <param name="coreResultsDir"/>

  <constant name="projectName">OrthoMCL</constant>
  <constant name="newPeripheralProteinsDir">$$projectName$$/newPeripheralProteins</constant>
  <constant name="newProteomesDir">$$newPeripheralProteinsDir$$/newPeripheralProteomes</constant>
  <constant name="updatePeripheralDir">$$projectName$$/updatePeripheralGroups</constant>
  <constant name="allPeripheralFastasDir">$$projectName$$/peripheralProteins/fastas</constant>
  <constant name="peripheralCheckSum">$$projectName$$/peripheralProteins/fastas/checkSum.tsv</constant>

  <!-- Create working directories -->
  <step name="makeUpdatePeripheralDir" stepClass="ReFlow::StepClasses::MakeDataDir">
    <paramValue name="dataDir">$$updatePeripheralDir$$</paramValue>
  </step>

  <step name="makeUpdatePeripheralAnalysisDir" stepClass="ReFlow::StepClasses::MakeDataDir">
    <paramValue name="dataDir">$$updatePeripheralDir$$/analysisDir</paramValue>
    <depends name="makeUpdatePeripheralDir"/>
  </step>

  <step name="makeUpdatePeripheralEntryResultsDir" stepClass="ReFlow::StepClasses::MakeDataDir">
    <paramValue name="dataDir">$$updatePeripheralDir$$/analysisDir/updatePeripheralEntryResults/</paramValue>
    <depends name="makeUpdatePeripheralAnalysisDir"/>
  </step>

  <step name="makeUpdateResidualEntryResultsDir" stepClass="ReFlow::StepClasses::MakeDataDir">
    <paramValue name="dataDir">$$updatePeripheralDir$$/analysisDir/updateResidualEntryResults/</paramValue>
    <depends name="makeUpdatePeripheralEntryResultsDir"/>
  </step>

  <step name="makePostUpdateEntryResultsDir" stepClass="ReFlow::StepClasses::MakeDataDir">
    <paramValue name="dataDir">$$updatePeripheralDir$$/analysisDir/postUpdateEntryResults/</paramValue>
    <depends name="makeUpdateResidualEntryResultsDir"/>
  </step>

  <!-- Prepare new peripheral proteomes (filter for longest transcript, compress) -->
  <step name="makeNewPeripheralProteinsDir" stepClass="ReFlow::StepClasses::MakeDataDir">
    <paramValue name="dataDir">$$newPeripheralProteinsDir$$</paramValue>
  </step>

  <step name="makeNewPeripheralFastasDir" stepClass="ReFlow::StepClasses::MakeDataDir">
    <paramValue name="dataDir">$$newPeripheralProteinsDir$$/fastas</paramValue>
    <depends name="makeNewPeripheralProteinsDir"/>
  </step>

  <step name="makeNewPeripheralProteomesDir" stepClass="ReFlow::StepClasses::MakeDataDir">
    <paramValue name="dataDir">$$newProteomesDir$$</paramValue>
    <depends name="makeNewPeripheralProteinsDir"/>
  </step>

  <!-- Copy only new or changed organism FASTAs into newProteomesDir using checksum diff -->
  <step name="copyNewPeripheralProteomesForUpdate" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::CopyNewPeripheralProteomesForUpdate">
    <paramValue name="currentCheckSum">$$peripheralCheckSum$$</paramValue>
    <paramValue name="sourceFastasDir">$$allPeripheralFastasDir$$</paramValue>
    <paramValue name="outputDir">$$newProteomesDir$$</paramValue>
    <depends name="makeNewPeripheralProteomesDir"/>
  </step>

  <step name="makeNewPeripheralInputDir" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::MakeOrthofinderPeripheralInputDir">
    <paramValue name="proteomesDir">$$newProteomesDir$$</paramValue>
    <paramValue name="outputDir">$$newPeripheralProteinsDir$$</paramValue>
    <depends name="makeNewPeripheralFastasDir"/>
    <depends name="copyNewPeripheralProteomesForUpdate"/>
  </step>

  <!-- Stage all required files from peripheral officialDiamondCache into update working dir -->
  <step name="copyAndUncompressUpdatePeripheralCacheDir" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::CopyAndUncompressUpdatePeripheralCacheDir">
    <paramValue name="outputDir">$$updatePeripheralDir$$</paramValue>
    <depends name="makePostUpdateEntryResultsDir"/>
  </step>

  <!-- Stage files from core workflow results (reformattedGroups.txt used for group assignment) -->
  <step name="copyCoreGroups" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::CopyDataDirFile">
    <paramValue name="fromFile">$$coreResultsDir$$/reformattedGroups.txt</paramValue>
    <paramValue name="toFile">$$updatePeripheralDir$$/reformattedGroups.txt</paramValue>
    <depends name="copyAndUncompressUpdatePeripheralCacheDir"/>
  </step>

  <step name="copyCoreDiamondResults" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::CopyDataDir">
    <paramValue name="fromDir">$$coreResultsDir$$/groupDiamondResults</paramValue>
    <paramValue name="toDir">$$updatePeripheralDir$$/groupDiamondResults</paramValue>
    <depends name="copyCoreGroups"/>
  </step>

  <step name="copyCoreSequenceIds" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::CopyDataDirFile">
    <paramValue name="fromFile">$$coreResultsDir$$/SequenceIDs.txt</paramValue>
    <paramValue name="toFile">$$updatePeripheralDir$$/SequenceIDs.txt</paramValue>
    <depends name="copyCoreDiamondResults"/>
  </step>

  <step name="copyCoreProteomes" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::CopyDataDirFile">
    <paramValue name="fromFile">$$coreProteome$$</paramValue>
    <paramValue name="toFile">$$updatePeripheralDir$$/coreFastas.tar.gz</paramValue>
    <depends name="copyCoreSequenceIds"/>
  </step>

  <!-- Symlink new peripheral proteomes tar into update working dir -->
  <step name="copyNewPeripheralProteomes" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::SymLinkDataDirFile">
    <paramValue name="fromFile">$$newPeripheralProteinsDir$$/fastas.tar.gz</paramValue>
    <paramValue name="toFile">$$updatePeripheralDir$$/fastas.tar.gz</paramValue>
    <depends name="makeNewPeripheralInputDir"/>
    <depends name="copyCoreProteomes"/>
  </step>

  <!-- Run the three update Nextflow entries sequentially -->
  <subgraph name="makeUpdatePeripheralGroups" xmlFile="orthoFinderUpdatePeripheral.xml">
    <paramValue name="projectName">$$projectName$$</paramValue>
    <paramValue name="updatePeripheralDir">$$updatePeripheralDir$$</paramValue>
    <depends name="copyNewPeripheralProteomes"/>
  </subgraph>

  <!-- Symlink update results into peripheralGroups/analysisDir/ so all downstream
       steps are path-agnostic between the full and update pipelines -->
  <step name="mapUpdateResultsToPeripheralDir" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::MapUpdateResultsToPeripheralDir">
    <paramValue name="peripheralDir">$$projectName$$/peripheralGroups</paramValue>
    <paramValue name="updatePeripheralDir">$$updatePeripheralDir$$</paramValue>
    <depends name="makeUpdatePeripheralGroups"/>
  </step>

  <constant name="peripheralDir">$$projectName$$/peripheralGroups</constant>

  <step name="copyPeripheralCheckSumToCache" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::CopyPeripheralCheckSumToCache">
    <paramValue name="checkSum">$$projectName$$/peripheralProteins/fastas/checkSum.tsv</paramValue>
    <depends name="mapUpdateResultsToPeripheralDir"/>
  </step>

  <step name="loadCoreGroups" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::InsertCoreGroups">
    <paramValue name="groupsFile">$$peripheralDir$$/analysisDir/peripheralEntryResults/GroupsFile.txt</paramValue>
    <paramValue name="gusConfigFile">$$projectName$$/$$projectName$$_gus.config</paramValue>
    <depends name="copyPeripheralCheckSumToCache"/>
  </step>

  <step name="loadResidualGroups" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::InsertResidualGroups">
    <paramValue name="groupsFile">$$peripheralDir$$/analysisDir/postResidualEntryResults/reformattedGroups.txt</paramValue>
    <paramValue name="gusConfigFile">$$projectName$$/$$projectName$$_gus.config</paramValue>
    <depends name="loadCoreGroups"/>
  </step>

  <step name="loadCoreGroupAASequence" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::InsertOrthoGroupAASequence">
    <paramValue name="groupsFile">$$peripheralDir$$/analysisDir/peripheralEntryResults/GroupsFile.txt</paramValue>
    <paramValue name="gusConfigFile">$$projectName$$/$$projectName$$_gus.config</paramValue>
    <depends name="loadResidualGroups"/>
  </step>

  <step name="loadResidualGroupAASequence" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::InsertOrthoGroupAASequence">
    <paramValue name="groupsFile">$$peripheralDir$$/analysisDir/postResidualEntryResults/reformattedGroups.txt</paramValue>
    <paramValue name="gusConfigFile">$$projectName$$/$$projectName$$_gus.config</paramValue>
    <depends name="loadCoreGroupAASequence"/>
  </step>

  <step name="insertOrthogroupCoreStats" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::InsertOrthoGroupStats" stepLoadTypes="plugin">
    <paramValue name="groupStatsFile">$$peripheralDir$$/analysisDir/peripheralEntryResults/groupStats/core_stats.txt</paramValue>
    <paramValue name="proteinSubset">C</paramValue>
    <paramValue name="gusConfigFile">$$projectName$$/$$projectName$$_gus.config</paramValue>
    <depends name="loadResidualGroupAASequence"/>
  </step>

  <step name="insertOrthogroupCorePeripheralStats" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::InsertOrthoGroupStats" stepLoadTypes="plugin">
    <paramValue name="groupStatsFile">$$peripheralDir$$/analysisDir/peripheralEntryResults/groupStats/peripheral_stats.txt</paramValue>
    <paramValue name="proteinSubset">C+P</paramValue>
    <paramValue name="gusConfigFile">$$projectName$$/$$projectName$$_gus.config</paramValue>
    <depends name="insertOrthogroupCoreStats"/>
  </step>

  <step name="insertOrthogroupResidualStats" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::InsertOrthoGroupStats" stepLoadTypes="plugin">
    <paramValue name="groupStatsFile">$$peripheralDir$$/analysisDir/postResidualEntryResults/groupStats/residual_stats.txt</paramValue>
    <paramValue name="proteinSubset">R</paramValue>
    <paramValue name="gusConfigFile">$$projectName$$/$$projectName$$_gus.config</paramValue>
    <depends name="insertOrthogroupCorePeripheralStats"/>
  </step>

  <step name="insertCoreOrthoGroupBlastValues" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::InsertOrthoGroupBlastValues" stepLoadTypes="plugin">
    <paramValue name="groupBlastValuesFile">$$peripheralDir$$/analysisDir/peripheralEntryResults/intraGroupBlastFile.tsv</paramValue>
    <paramValue name="gusConfigFile">$$projectName$$/$$projectName$$_gus.config</paramValue>
    <depends name="insertOrthogroupResidualStats"/>
  </step>

  <step name="insertResidualOrthoGroupBlastValues" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::InsertOrthoGroupBlastValues" stepLoadTypes="plugin">
    <paramValue name="groupBlastValuesFile">$$peripheralDir$$/analysisDir/postResidualEntryResults/intraResidualGroupBlastFile.tsv</paramValue>
    <paramValue name="gusConfigFile">$$projectName$$/$$projectName$$_gus.config</paramValue>
    <depends name="insertCoreOrthoGroupBlastValues"/>
  </step>

  <step name="insertSimilarOrthologgroups" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::InsertSimilarOrthologGroups" stepLoadTypes="plugin">
    <paramValue name="similarGroups">$$peripheralDir$$/analysisDir/postProcessingEntryResults/similar_groups.tsv</paramValue>
    <paramValue name="gusConfigFile">$$projectName$$/$$projectName$$_gus.config</paramValue>
    <depends name="insertResidualOrthoGroupBlastValues"/>
  </step>

  <step name="insertPreviousGroupMapping" stepClass="ApiCommonWorkflow::Main::WorkflowSteps::InsertPreviousGroupMapping" stepLoadTypes="plugin">
    <paramValue name="mappingFile">$$peripheralDir$$/analysisDir/postProcessingEntryResults/previousGroups.txt</paramValue>
    <paramValue name="gusConfigFile">$$projectName$$/$$projectName$$_gus.config</paramValue>
    <depends name="mapUpdateResultsToPeripheralDir"/>
  </step>

</workflowGraph>
